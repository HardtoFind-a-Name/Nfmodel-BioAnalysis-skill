manifest {
    name            = 'transcriptome-prognosis-pipeline'
    author          = 'LMH'
    homePage        = 'local'
    description     = 'Multi-model transcriptome prognosis pipeline with Nextflow and R.'
    nextflowVersion = '>=23.10.0'
}

params {
    // --- User / project ---
    user_id       = System.getenv('USER') ?: 'default_user'
    project_id    = 'nf_r_test_2'

    user_dir      = "/data/nas1/${params.user_id}"
    project_root  = "${params.user_dir}/project"
    run_dir       = "${params.project_root}/${params.project_id}"
    clean_root    = "${params.user_dir}/data_cleaned"

    // --- Analysis sequence numbers (output dir prefixes) ---
    deg_SN             = '01'
    candidate_SN       = '02'
    go_kegg_SN         = '03'
    multi_model_SN     = '04'

    // --- Output paths ---
    results_dir  = "${params.run_dir}/results"
    outdir       = "${params.results_dir}"
    logdir       = "${params.run_dir}/logs"
    summary_dir  = "${params.run_dir}/summarys"
    work_dir     = "${params.run_dir}/work"
    nf_log_dir   = "${params.run_dir}/NFlogs"
    rawdata_dir  = "${params.results_dir}/00_rawdata"

    // --- Data source identifiers ---
    train_id         = 'TCGA-LUAD'
    validation_ids   = ''

    // --- Training data paths (derived in workflow, placeholders here) ---
    train_id_lower    = null  // computed in main.nf from train_id
    count_matrix      = null
    group_table       = null
    survival_table    = null
    clinical_table    = null

    // --- Expression matrix type ---
    expr_type         = 'fpkm'
    tpm_matrix        = null  // computed in main.nf
    fpkm_matrix       = null
    expr_matrix       = null

    // --- Validation ---
    validation_sheet        = "${params.run_dir}/validation_sheet.csv"
    validation_output_dir   = params.validation_sheet

    // --- Candidate genes ---
    candidate_genes          = null
    gene_sets_sheet          = null

    // --- External databases ---
    database_root            = '/data/nas1/public_JOB062/database'
    metascape_input_file     = "${params.database_root}/metascape/00.FINAL_GO.csv"
    string_interactions_file = "${params.database_root}/string/00.string_interactions.tsv"

    // --- Post-modeling external data ---
    gmt_dir           = "${params.database_root}/MSigdb"
    gmt_gsea_gene     = "c2.cp.kegg.v7.4.symbols.gmt,c5.go.bp.v7.4.symbols.gmt"
    gmt_gsea_risk     = "c2.cp.kegg.v7.4.symbols.gmt"
    gsea_sort_by      = "p.adjust"
    cnv_download_dir  = "${params.database_root}/CNV_downloads"
    gistic_matrix     = null
    ips_file          = "${params.database_root}/TCIA/${params.train_id}_ClinicalData.tsv"
    maf_file          = "${params.database_root}/TMB/LUAD.maf"

    // --- Step toggles ---
    run_deg                        = true
    run_candidate_genes            = false
    run_intersect_candidate_genes  = true
    run_go_kegg_ppi                = true
    run_multi_model                = true
    run_lasso_select               = true
    run_model_A1                   = true
    run_model_A2                   = true
    run_model_A3                   = true
    run_model_A4                   = true
    run_model_A5                   = true
    run_model_A6                   = true
    run_model_A7                   = true
    run_model_B1                   = true
    run_model_B2                   = true
    run_model_B3                   = true
    // --- Post-modeling analyses (all default off, require --risk_file) ---
    stage_SN              = 'xx'
    gsea_gene_SN          = 'xx'
    gsea_risk_nes_SN      = 'xx'
    cibersort_SN          = 'xx'
    cnv_SN                = 'xx'
    gistic_SN             = 'xx'
    tide_SN               = 'xx'
    ips_SN                = 'xx'
    diff_expr_SN          = 'xx'
    circos_SN             = 'xx'
    tmb_SN                = 'xx'
    risk_file             = null
    gene_file             = null
    gwas_file             = "${params.database_root}/GWAS/gwas-association.tsv"
    tidepy_bin            = System.getenv('NFMODELS_TIDEPY_BIN') ?: 'tidepy'
    tidepy_cache_dir      = "${params.user_dir}/app/tidepy/${params.train_id}"

    // --- Stage prognostic params ---
    stage_time_set        = '135'
    stage_dca_year        = '3'
    stage_min_level_n     = '5'
    stage_variables       = null

    run_stage              = false
    run_gsea_gene          = false
    run_gsea_risk_nes      = false
    run_cibersort          = false
    run_cnv                = false
    run_gistic             = false
    run_tide               = false
    run_ips                = false
    run_diff_expr          = false
    run_circos             = false
    run_tmb                = false

    run_clinical_nomogram          = false

    // --- DEG params ---
    deg_p_cutoff         = 0.05
    deg_logfc_cutoff     = 2
    deg_use_pvalue       = false
    min_count            = 10
    min_prop             = 0.20

    // --- Unicox parameters ---
    unicox_p_cutoff      = 0.05
    ph_p_cutoff          = 0.05

    // --- TimeROC ---
    time_roc_points_days     = '365,1095,1825'
    time_roc_points_days_alt = '1095,1825,2555'
    run_time_set_alt         = true

    // --- GO/KEGG/PPI ---
    go_top_n_each        = 10
    kegg_top_n           = 10
    go_kegg_adj_cutoff   = 0.05
    go_kegg_fallback_p   = 0.05
    kegg_gmt             = "${params.database_root}/msigdb/c2.cp.kegg.v7.4.symbols.gmt"
    kegg_gmt_id_type     = 'SYMBOL'
    ppi_score_cutoff     = 0.4
    ppi_hub_top_n        = 10

    // --- Model thresholds ---
    model_auc_threshold  = 0.6

    // --- RSF hyperparameters ---
    rsf_ntree_range      = '100,200,300,500,1000'
    rsf_mtry_range       = '1,2,3'
    rsf_nodesize_range   = '5,10,15,20,25,30'
    rsf_seed             = 10

    // --- CoxBoost hyperparameters ---
    coxboost_maxstepno_range = '50,100,200,500'
    coxboost_penalty_range   = '10,50,100,200,500'

    // --- Runtime commands from NFmodels/.env ---
    rscript    = System.getenv('NFMODELS_RSCRIPT_CMD') ?: ''
    python_cmd = System.getenv('NFMODELS_PYTHON_CMD') ?: ''
}

workDir = "${params.work_dir}"

includeConfig 'conf/base.config'
includeConfig 'conf/local.config'

profiles {
    local {
        process.executor = 'local'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
}
