process {
    cpus   = 2
    memory = '4 GB'
    time   = '4h'
    shell  = ['/bin/bash', '-euo', 'pipefail']

    withName: DEG_DESEQ2 {
        cpus = 2
        memory = '8 GB'
        time = '8h'
    }

    withName: DEG_FILTER_PLOT {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: GSEA_CANDIDATE_GENES {
        cpus = 2
        memory = '8 GB'
        time = '6h'
    }

    withName: INTERSECT_CANDIDATE_GENES {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: GO_KEGG_PPI {
        cpus = 2
        memory = '6 GB'
        time = '4h'
    }

    withName: UNICOX_SCREEN {
        cpus = 2
        memory = '8 GB'
        time = '6h'
    }

    withName: LASSO_SELECT {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withName: 'MULTICOX_*' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: 'STEPCOX_*' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: COXBOOST_SELECT {
        cpus = 2
        memory = '8 GB'
        time = '6h'
    }

    withName: 'TRAIN_*' {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withName: 'VALIDATE_*' {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withName: 'RSF_*' {
        cpus = 4
        memory = '16 GB'
        time = '12h'
    }

    withName: MULTI_MODEL_SUMMARY {
        cpus = 1
        memory = '2 GB'
        time = '1h'
    }

    withName: CLINICAL_NOMOGRAM {
        cpus = 2
        memory = '8 GB'
        time = '8h'
    }
}

timeline {
    enabled = true
    file = "${params.run_dir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.run_dir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.run_dir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    file = "${params.run_dir}/pipeline_info/dag.mmd"
    overwrite = true
}
